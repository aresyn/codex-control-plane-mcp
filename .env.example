# Codex Control Plane MCP write defaults.
# MCP clients can override these per tool call with explicit sandbox and
# approval_policy arguments.

CODEX_MCP_DEFAULT_SANDBOX=danger-full-access
CODEX_MCP_DEFAULT_APPROVAL_POLICY=never

# Optional DeepSeek summarization settings.
# The MCP server works without this file; large chat summaries will be skipped
# or use local short-history summaries when no API key is configured.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_SUMMARY_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_MAX_RETRIES=1
