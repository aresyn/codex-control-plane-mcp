# Codex Control Plane MCP write defaults.
# MCP clients can override these per tool call with explicit sandbox and
# approval_policy arguments.
# Plan Mode has a runtime floor: read-only is raised to workspace-write.

CODEX_MCP_DEFAULT_SANDBOX=read-only
CODEX_MCP_DEFAULT_APPROVAL_POLICY=on-request
CODEX_MCP_MAX_IMAGE_INPUT_ITEMS=10
CODEX_MCP_MAX_IMAGE_INPUT_BYTES=20000000
CODEX_MCP_TURN_STALL_TIMEOUT_SECONDS=900
CODEX_MCP_STALLED_TURN_ACTION=diagnose_only
CODEX_MCP_EXECUTION_MODE=inline
CODEX_MCP_MAX_ACTIVE_TURNS_GLOBAL=4
CODEX_MCP_MAX_ACTIVE_TURNS_PER_PROJECT=3
CODEX_MCP_MAX_ACTIVE_TURNS_PER_AGENT=3
CODEX_MCP_MAX_ACTIVE_TURNS_PER_THREAD=1
CODEX_MCP_MAX_ACTIVE_WRITE_TURNS_PER_PROJECT=1
CODEX_MCP_MAX_APP_SERVER_PENDING_REQUESTS=8

# Optional DeepSeek summarization settings.
# The MCP server works without this file; large chat summaries will be skipped
# or use local short-history summaries when no API key is configured.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_SUMMARY_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_MAX_RETRIES=1
